{
  "name": "fridgefriend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "chroma": "node scripts/chroma-server.mjs",
    "dev": "node scripts/dev-server.mjs",
    "langgraph:dev": "langgraphjs dev --config ./langgraph.json",
    "langgraph:up": "langgraphjs up --config ./langgraph.json",
    "prompts:push": "node scripts/push-langsmith-prompts.mjs",
    "recipes:index": "tsx scripts/index-recipes.ts",
    "recipes:demo:seed": "tsx scripts/seed-demo-corpus.ts",
    "recipes:demo:preembed": "tsx scripts/build-preembedded-demo-data.ts",
    "recipes:demo:verify": "tsx scripts/seed-demo-corpus.ts",
    "recipes:demo:select": "tsx scripts/select-demo-recipe-corpus.ts",
    "recipes:tags:index": "tsx scripts/index-recipe-tags.ts",
    "dataset:seed-scan": "node scripts/seed-langsmith-scan-dataset.mjs",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "react-router typegen && tsc",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
