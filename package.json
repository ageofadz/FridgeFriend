    "@llamaindex/chat-ui": "^0.6.1",
    "@react-router/node": "^8.2.0",
    "@react-router/serve": "^8.2.0",
    "@swc/helpers": "^0.5.23",
    "better-sqlite3": "^12.5.0",
    "chromadb": "^3.0.23",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.32",
    "jpeg-js": "^0.4.4",
    "langchain": "^1.0.0",
    "langsmith": "^0.3.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^8.2.0",
    "three": "^0.185.1"
