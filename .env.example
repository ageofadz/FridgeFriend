# Google Gemini API key used for vision scans and query inference (required).
GOOGLE_API_KEY=

# LangSmith observability. Set all three together (or none): traces, prompt
# hub pulls, and evals are enabled when the configuration is complete.
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Tracing is enabled automatically when the LangSmith configuration above is
# complete. Set to "false" to keep Prompt Hub pulls without sending traces.
# LANGSMITH_TRACING=true

# SQLite database location (optional, defaults to .data/fridgefriend.sqlite).
# DATABASE_PATH=.data/fridgefriend.sqlite

# Chroma vector store URL for recipe retrieval (optional, e.g. http://localhost:8000).
# CHROMA_URL=
